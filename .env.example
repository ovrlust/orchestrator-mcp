# Copy to .env and fill in. Loaded at startup by server.py / `python -m backend`.

# Worker endpoint key — required for any live worker call.
OPENROUTER_API_KEY=sk-or-...

# Optional: point workers at any OpenAI-compatible base instead of OpenRouter.
# DELEGATE_BASE_URL=https://openrouter.ai/api/v1
# DELEGATE_API_KEY=

# Optional: default cheap worker model.
# ASK_MODEL_DEFAULT=openai/gpt-4o-mini

# Optional: enables the worker web_search tool.
# TAVILY_API_KEY=tvly-...

# Worker reliability knobs (see workers.py for the full list).
# DELEGATE_MAX_CONCURRENCY=8
# DELEGATE_TIMEOUT=180
# DELEGATE_RETRIES=4
